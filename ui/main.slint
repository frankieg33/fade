import { FadeTheme } from "style.slint";
import { Button, VerticalBox, HorizontalBox, LineEdit, ComboBox, CheckBox, Slider, ScrollView } from "std-widgets.slint";
import "SymbolsNerdFontMono-Regular.ttf";

// An application row inside a group card
export struct GroupAppModel {
    icon: string,           // Nerd Font glyph
    process: string,        // e.g. "chrome.exe"
    customized: bool,       // true if an app_rule overrides the group
    enabled: bool,          // from app_rule if customized, else bucket.enabled
    timeout-mins: int,      // from app_rule if customized, else bucket value
    action: string,         // from app_rule if customized, else bucket value
}

// A group card (bucket)
export struct GroupModel {
    icon: string,           // Nerd Font bucket icon
    name: string,           // e.g. "Browsing"
    enabled: bool,          // bucket.enabled
    timeout-mins: int,      // bucket.timeout_mins
    action: string,         // bucket.action
    apps: [GroupAppModel],  // processes in this bucket
    expanded: bool,
}

// An unassigned app rule (not in any bucket)
export struct UnassignedRuleModel {
    icon: string,
    process: string,
    timeout-mins: int,
    action: string,
    enabled: bool,
}

// Active process in the drawer
export struct ActiveProcessModel {
    icon: string,
    process: string,
    managed: bool,          // already has a rule or is in a bucket
}

// Icon picker entry
export struct IconEntry {
    glyph: string,
    keywords: string,
}

// A row in the Activity log
export struct ActivityLogModel {
    icon: string,
    process: string,
    action: string,      // "minimize" or "close"
    time_str: string,    // relative time, e.g. "3m ago"
    title: string,
}

// Currently-open app shown at top of Activity page.
export struct CurrentAppModel {
    icon: string,
    process_name: string,
    idle_str: string,    // e.g. "active now", "3m ago"
    managed: bool,
}

// Visible-when-unchecked checkbox (the std-widgets CheckBox was too faint on dark bg).
component FadeCheck inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled();
    width: 20px;
    height: 20px;
    border-radius: 4px;
    border-width: 2px;
    border-color: root.checked ? FadeTheme.accent : FadeTheme.text-dim;
    background: root.checked ? FadeTheme.accent : (ta.has-hover ? FadeTheme.surface-hover : transparent);
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
    if root.checked: Text {
        text: "✓";
        color: FadeTheme.bg;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Renders a brand-name SVG (arc, vivaldi, slack, etc.) when `icon` matches a known
// slug, otherwise falls back to rendering `icon` as a Nerd Font glyph.
//
// MAINTENANCE: To add a new brand SVG, you must update THREE places:
//   1. drop the SVG file into assets/icons/<slug>.svg
//   2. add `if root.icon == "<slug>": Image { source: @image-url("..."); ... }` below
//   3. add `|| root.icon == "<slug>"` to the `is-brand` property
// Forgetting (3) makes the glyph fallback render on top of the SVG.
component BrandIcon inherits Rectangle {
    in property <string> icon;
    in property <length> size: 18px;
    in property <color> tint: FadeTheme.text;

    width: root.size;
    height: root.size;

    property <bool> is-brand:
        root.icon == "arc" || root.icon == "vivaldi" || root.icon == "brave" ||
        root.icon == "opera" || root.icon == "googlechrome" || root.icon == "firefox" ||
        root.icon == "discord" || root.icon == "telegram" || root.icon == "signal" ||
        root.icon == "whatsapp" || root.icon == "spotify" || root.icon == "vlcmediaplayer" ||
        root.icon == "itunes" || root.icon == "intellijidea" || root.icon == "androidstudio" ||
        root.icon == "steam" || root.icon == "epicgames" || root.icon == "gogdotcom" ||
        root.icon == "slack" || root.icon == "visualstudiocode" || root.icon == "visualstudio" ||
        root.icon == "powershell" || root.icon == "windowsterminal" ||
        root.icon == "anthropic" || root.icon == "openai" ||
        root.icon == "googlegemini" || root.icon == "cursor";

    if root.icon == "arc": Image { source: @image-url("../assets/icons/arc.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "vivaldi": Image { source: @image-url("../assets/icons/vivaldi.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "brave": Image { source: @image-url("../assets/icons/brave.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "opera": Image { source: @image-url("../assets/icons/opera.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "googlechrome": Image { source: @image-url("../assets/icons/googlechrome.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "firefox": Image { source: @image-url("../assets/icons/firefox.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "discord": Image { source: @image-url("../assets/icons/discord.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "telegram": Image { source: @image-url("../assets/icons/telegram.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "signal": Image { source: @image-url("../assets/icons/signal.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "whatsapp": Image { source: @image-url("../assets/icons/whatsapp.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "spotify": Image { source: @image-url("../assets/icons/spotify.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "vlcmediaplayer": Image { source: @image-url("../assets/icons/vlcmediaplayer.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "itunes": Image { source: @image-url("../assets/icons/itunes.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "intellijidea": Image { source: @image-url("../assets/icons/intellijidea.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "androidstudio": Image { source: @image-url("../assets/icons/androidstudio.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "steam": Image { source: @image-url("../assets/icons/steam.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "epicgames": Image { source: @image-url("../assets/icons/epicgames.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "gogdotcom": Image { source: @image-url("../assets/icons/gogdotcom.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "slack": Image { source: @image-url("../assets/icons/slack.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "visualstudiocode": Image { source: @image-url("../assets/icons/visualstudiocode.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "visualstudio": Image { source: @image-url("../assets/icons/visualstudio.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "powershell": Image { source: @image-url("../assets/icons/powershell.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "windowsterminal": Image { source: @image-url("../assets/icons/windowsterminal.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "anthropic": Image { source: @image-url("../assets/icons/anthropic.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "openai": Image { source: @image-url("../assets/icons/openai.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "googlegemini": Image { source: @image-url("../assets/icons/googlegemini.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }
    if root.icon == "cursor": Image { source: @image-url("../assets/icons/cursor.svg"); width: root.size; height: root.size; image-fit: contain; colorize: root.tint; }

    if !root.is-brand: Text {
        text: root.icon;
        font-family: "Symbols Nerd Font Mono";
        font-size: root.size;
        color: root.tint;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: root.size;
        height: root.size;
    }
}

component FadeDeleteButton inherits Rectangle {
    in property <bool> confirming: false;
    in property <string> confirm-label: "Delete?";
    in property <length> compact-width: 28px;
    in property <length> confirm-width: 60px;
    in property <length> button-height: 26px;
    callback clicked();

    width: root.confirming ? root.confirm-width : root.compact-width;
    height: root.button-height;
    border-radius: 4px;
    border-width: 1px;
    border-color: FadeTheme.danger;
    background: root.confirming
        ? FadeTheme.danger
        : delete-ta.has-hover ? FadeTheme.danger-soft-hover : FadeTheme.danger-soft;

    delete-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.confirming ? root.confirm-label : "✕";
        font-size: root.confirming ? 11px : 16px;
        font-weight: root.confirming ? 600 : 700;
        color: root.confirming ? FadeTheme.bg : delete-ta.has-hover ? FadeTheme.bg : FadeTheme.danger;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component SettingsWindow inherits Window {
    title: "Fade — Managed Applications";
    icon: @image-url("Fade Icon.png");
    preferred-width: 880px;
    preferred-height: 640px;
    min-width: 820px;
    min-height: 400px;
    background: FadeTheme.bg;

    // Properties bound from Rust
    in property <[GroupModel]> groups;
    in property <[UnassignedRuleModel]> unassigned-rules;
    in property <[ActiveProcessModel]> active-processes;
    in property <[ActivityLogModel]> activity-log;
    in property <[CurrentAppModel]> current-apps;
    in property <int> managed-count: 0;
    in property <int> active-count: 0;
    in property <int> polling-interval-secs: 30;
    // Bumped each refresh tick by Rust to force Slint to mark the window dirty.
    // The software renderer otherwise can keep showing a stale framebuffer after
    // long idle periods until a hover event invalidates a region.
    in property <int> redraw-tick: 0;
    in property <bool> auto-start: false;
    in property <string> version: "0.0.0";
    in-out property <bool> paused: false;

    // Navigation state
    in-out property <int> current-page: 0; // 0 = Applications & Rules, 1 = General Settings, 2 = Activity

    // Search
    in-out property <string> search-text: "";

    // Drawer visibility + status
    in-out property <bool> drawer-open: false;
    // 0 = none, 1 = success, 2 = warning (already added), 3 = error (empty/invalid)
    in-out property <int> drawer-status-kind: 0;
    in-out property <string> drawer-status-text: "";

    // Rename: which group is currently being renamed (-1 = none)
    in-out property <int> renaming-group: -1;

    // Icon picker state
    in-out property <int> icon-picker-group: -1;  // -1 = picker closed
    in-out property <int> icon-picker-app: -1;    // -1 = picking group icon; else app idx within group
    in-out property <string> icon-search-text: "";
    in property <[IconEntry]> icon-results;
    in-out property <string> icon-hovered-name: "";

    // Kebab menu state (move/remove app)
    in-out property <int> kebab-group: -1;
    in-out property <int> kebab-app: -1;
    // Kebab menu for unassigned rules (-1 = closed)
    in-out property <int> unassigned-kebab: -1;

    // Restore-defaults confirmation state
    in-out property <bool> confirming-reset: false;
    // Group-delete confirmation: -1 = none, else group idx awaiting second click
    in-out property <int> confirming-delete-group: -1;

    // Group callbacks
    callback toggle-group(int /* group idx */, bool /* enabled */);
    callback update-group-timeout(int /* group idx */, int /* mins */);
    callback update-group-action(int /* group idx */, string /* action */);
    callback add-app-to-group(int /* group idx */, string /* process */);
    callback toggle-group-expanded(int /* group idx */);
    callback rename-group(int /* group idx */, string /* new name */);
    callback create-group();
    callback delete-group(int /* group idx */);
    callback move-to-new-group(int /* from group */, int /* app idx */);
    callback assign-to-new-group(int /* unassigned idx */);
    callback set-group-icon(int /* group idx */, string /* glyph */);
    callback set-app-icon(int /* group idx */, int /* app idx */, string /* glyph */);
    callback icon-search-changed(string /* query */);
    callback move-app(int /* from group */, int /* app idx */, int /* to group */);
    callback remove-from-group(int /* group idx */, int /* app idx */);
    callback delete-app-from-group(int /* group idx */, int /* app idx */);
    callback add-to-group(int /* group idx */, string /* process */);
    callback move-app-up(int /* group idx */, int /* app idx */);
    callback move-app-down(int /* group idx */, int /* app idx */);
    callback assign-to-group(int /* unassigned idx */, int /* to group */);

    // App-in-group callbacks
    callback customize-app(int /* group idx */, int /* app idx */);
    callback reset-app-to-group(int /* group idx */, int /* app idx */);
    callback update-app-timeout(int /* group idx */, int /* app idx */, int /* mins */);
    callback update-app-action(int /* group idx */, int /* app idx */, string /* action */);
    callback toggle-app(int /* group idx */, int /* app idx */, bool /* enabled */);

    // Unassigned rule callbacks
    callback remove-unassigned(int /* idx */);
    callback toggle-unassigned(int /* idx */, bool /* enabled */);
    callback update-unassigned-timeout(int /* idx */, int /* mins */);
    callback update-unassigned-action(int /* idx */, string /* action */);

    // Drawer callbacks
    callback add-rule(string /* process */);
    callback add-process-name(string /* process */);

    // General settings callbacks
    callback set-polling-interval(int /* secs */);
    callback set-auto-start(bool);
    callback hide-process(string /* process */);
    callback restore-defaults();
    callback search-changed(string /* query */);

    // ═══════════════════════════════════════════════
    // MAIN LAYOUT: sidebar + content
    // ═══════════════════════════════════════════════
    // Full-bleed backdrop — prevents stale pixels from leaking through
    // when the window is shown after a long hide (Slint compositor quirk).
    Rectangle { background: FadeTheme.bg; }

    // Global Esc handler for dismissing popups
    esc-scope := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.icon-picker-group = -1;
                root.icon-picker-app = -1;
                root.kebab-group = -1;
                root.kebab-app = -1;
                root.unassigned-kebab = -1;
                root.drawer-open = false;
                root.renaming-group = -1;
                root.confirming-delete-group = -1;
                return accept;
            }
            reject
        }
    }

    // Invisible 1px sentinel that depends on redraw-tick. Whenever Rust bumps the
    // property the renderer sees a mutation and repaints the whole window — fixes
    // the software-renderer staleness after long idle periods.
    Rectangle {
        x: 0px;
        y: 0px;
        width: 1px;
        height: 1px;
        opacity: root.redraw-tick * 0.0001 + 0.0001;
        background: FadeTheme.bg;
    }

    HorizontalBox {
        padding: 0px;
        spacing: 0px;

        // ── Sidebar ──
        Rectangle {
            width: FadeTheme.sidebar-width;
            background: FadeTheme.sidebar-bg;

            VerticalBox {
                padding-top: 16px;
                padding-bottom: 8px;
                spacing: 0px;

                // Logo area
                HorizontalBox {
                    padding-left: 16px;
                    padding-bottom: 16px;
                    spacing: 8px;
                    alignment: start;
                    Image {
                        source: @image-url("Fade Icon.png");
                        width: 32px;
                        height: 32px;
                    }
                    Text {
                        text: "Fade";
                        color: FadeTheme.accent;
                        font-size: 20px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                // Nav: Rules
                Rectangle {
                    height: 36px;
                    border-radius: FadeTheme.radius;
                    background: root.current-page == 0 ? FadeTheme.sidebar-active : nav0-ta.has-hover ? FadeTheme.surface-hover : transparent;
                    nav0-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.confirming-delete-group = -1;
                            root.current-page = 0;
                        }
                    }
                    HorizontalBox {
                        padding-left: 12px;
                        spacing: 8px;
                        Text {
                            text: "\u{F0485}";
                            font-family: "Symbols Nerd Font Mono";
                            font-size: 14px;
                            color: root.current-page == 0 ? FadeTheme.sidebar-active-text : FadeTheme.sidebar-text;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Rules";
                            font-size: 13px;
                            color: root.current-page == 0 ? FadeTheme.sidebar-active-text : FadeTheme.sidebar-text;
                            vertical-alignment: center;
                        }
                    }
                }

                // Nav: Activity
                Rectangle {
                    height: 36px;
                    border-radius: FadeTheme.radius;
                    background: root.current-page == 2 ? FadeTheme.sidebar-active : nav2-ta.has-hover ? FadeTheme.surface-hover : transparent;
                    nav2-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.confirming-delete-group = -1;
                            root.current-page = 2;
                        }
                    }
                    HorizontalBox {
                        padding-left: 12px;
                        spacing: 8px;
                        Text {
                            text: "\u{F0150}";
                            font-family: "Symbols Nerd Font Mono";
                            font-size: 14px;
                            color: root.current-page == 2 ? FadeTheme.sidebar-active-text : FadeTheme.sidebar-text;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Activity";
                            font-size: 13px;
                            color: root.current-page == 2 ? FadeTheme.sidebar-active-text : FadeTheme.sidebar-text;
                            vertical-alignment: center;
                        }
                    }
                }

                // Spacer pushes Settings to the bottom
                Rectangle { vertical-stretch: 1; }

                // Nav: Settings (bottom)
                Rectangle {
                    height: 36px;
                    border-radius: FadeTheme.radius;
                    background: root.current-page == 1 ? FadeTheme.sidebar-active : nav1-ta.has-hover ? FadeTheme.surface-hover : transparent;
                    nav1-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.confirming-delete-group = -1;
                            root.current-page = 1;
                        }
                    }
                    HorizontalBox {
                        padding-left: 12px;
                        spacing: 8px;
                        Text {
                            text: "\u{F0493}";
                            font-family: "Symbols Nerd Font Mono";
                            font-size: 14px;
                            color: root.current-page == 1 ? FadeTheme.sidebar-active-text : FadeTheme.sidebar-text;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "Settings";
                            font-size: 13px;
                            color: root.current-page == 1 ? FadeTheme.sidebar-active-text : FadeTheme.sidebar-text;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── Content area ──
        Rectangle {
            horizontal-stretch: 1;
            background: FadeTheme.bg;

            TouchArea {
                clicked => { root.confirming-delete-group = -1; }
            }

            // Page 0: Applications & Rules
            if root.current-page == 0: VerticalBox {
                padding: 20px;
                spacing: 12px;

                // Header row
                HorizontalBox {
                    spacing: 12px;
                    VerticalBox {
                        spacing: 2px;
                        horizontal-stretch: 1;
                        Text {
                            text: "Managed Applications";
                            color: FadeTheme.text;
                            font-size: 18px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.managed-count + " Applications Managed | " + root.active-count + " Windows Active";
                            color: FadeTheme.text-dim;
                            font-size: 12px;
                        }
                    }
                    // Search box
                    Rectangle {
                        width: 220px;
                        height: 30px;
                        background: FadeTheme.input-bg;
                        border-radius: FadeTheme.radius;
                        border-width: 1px;
                        border-color: FadeTheme.border;
                        HorizontalBox {
                            padding-top: 0px;
                            padding-bottom: 0px;
                            padding-left: 8px;
                            padding-right: 0px;
                            spacing: 4px;
                            Text {
                                text: "\u{F0349}";
                                font-family: "Symbols Nerd Font Mono";
                                font-size: 13px;
                                color: FadeTheme.text-dim;
                                vertical-alignment: center;
                                width: 20px;
                            }
                            search-input := LineEdit {
                                horizontal-stretch: 1;
                                placeholder-text: "Search apps...";
                                text <=> root.search-text;
                                changed has-focus => {
                                    if (self.has-focus) {
                                        root.confirming-delete-group = -1;
                                    }
                                }
                                edited(val) => { root.search-changed(val); }
                            }
                        }
                    }
                }

                // Section heading
                Text {
                    text: "Combined Rules & Buckets";
                    color: FadeTheme.text-dim;
                    font-size: 13px;
                    font-weight: 600;
                }

                ScrollView {
                    vertical-stretch: 1;
                    VerticalBox {
                        spacing: 12px;

                        // ── Group cards ──
                        for group[g-idx] in root.groups: Rectangle {
                            border-radius: FadeTheme.radius;
                            background: FadeTheme.card-bg;
                            border-width: 1px;
                            border-color: FadeTheme.border;

                            VerticalBox {
                                padding: 0px;
                                spacing: 0px;

                                // Card header
                                Rectangle {
                                    height: 44px;
                                    border-radius: FadeTheme.radius;
                                    background: FadeTheme.card-header-bg;

                                    header-ta := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.confirming-delete-group = -1;
                                            root.toggle-group-expanded(g-idx);
                                        }
                                    }

                                    HorizontalBox {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        spacing: 8px;

                                        VerticalLayout {
                                            alignment: center;
                                            FadeCheck {
                                                checked: group.enabled;
                                                toggled => { root.toggle-group(g-idx, self.checked); }
                                            }
                                        }
                                        Rectangle {
                                            width: 28px;
                                            height: 28px;
                                            border-radius: 4px;
                                            background: grp-icon-ta.has-hover ? FadeTheme.surface-hover : transparent;
                                            grp-icon-ta := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.confirming-delete-group = -1;
                                                    root.icon-picker-group = g-idx;
                                                    root.icon-picker-app = -1;
                                                    root.icon-search-text = "";
                                                    root.icon-hovered-name = "";
                                                    root.icon-search-changed("");
                                                }
                                            }
                                            Text {
                                                text: group.icon;
                                                font-family: "Symbols Nerd Font Mono";
                                                font-size: 16px;
                                                color: FadeTheme.accent;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        if root.renaming-group != g-idx: Text {
                                            text: group.name;
                                            color: FadeTheme.text;
                                            font-size: 14px;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        if root.renaming-group == g-idx: LineEdit {
                                            text: group.name;
                                            horizontal-stretch: 1;
                                            font-size: 14px;
                                            changed has-focus => {
                                                if (self.has-focus) {
                                                    root.confirming-delete-group = -1;
                                                }
                                            }
                                            accepted(val) => {
                                                root.rename-group(g-idx, val);
                                                root.renaming-group = -1;
                                            }
                                        }
                                        // Rename pencil
                                        Rectangle {
                                            width: 30px;
                                            height: 30px;
                                            border-radius: 4px;
                                            background: rename-ta.has-hover ? FadeTheme.surface-hover : transparent;
                                            rename-ta := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.confirming-delete-group = -1;
                                                    root.renaming-group = root.renaming-group == g-idx ? -1 : g-idx;
                                                }
                                            }
                                            Text {
                                                text: "\u{F03EB}";
                                                font-family: "Symbols Nerd Font Mono";
                                                font-size: 16px;
                                                color: rename-ta.has-hover ? FadeTheme.accent : FadeTheme.text-dim;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        // Group timeout — label stacked above slider to save width
                                        Rectangle {
                                            width: 110px;
                                            VerticalLayout {
                                                spacing: 2px;
                                                Text {
                                                    text: Math.round(grp-slider.value) * 5 + " min";
                                                    color: FadeTheme.text;
                                                    font-size: 11px;
                                                    horizontal-alignment: center;
                                                }
                                                grp-slider := Slider {
                                                    minimum: 1;
                                                    maximum: 24;
                                                    value: Math.ceil(group.timeout-mins / 5);
                                                    changed(val) => {
                                                        root.confirming-delete-group = -1;
                                                        root.update-group-timeout(g-idx, Math.round(val) * 5);
                                                    }
                                                }
                                            }
                                        }
                                        ComboBox {
                                            width: 95px;
                                            model: ["minimize", "close"];
                                            current-value: group.action;
                                            selected(val) => {
                                                root.confirming-delete-group = -1;
                                                root.update-group-action(g-idx, val);
                                            }
                                        }
                                        // Delete group button (two-click confirm)
                                        FadeDeleteButton {
                                            compact-width: 28px;
                                            confirm-width: 60px;
                                            button-height: 26px;
                                            confirming: root.confirming-delete-group == g-idx;
                                            clicked => {
                                                if (root.confirming-delete-group == g-idx) {
                                                    root.delete-group(g-idx);
                                                    root.confirming-delete-group = -1;
                                                } else {
                                                    root.confirming-delete-group = g-idx;
                                                }
                                            }
                                        }
                                        // Chevron
                                        Text {
                                            text: group.expanded ? "\u{F0140}" : "\u{F0142}";
                                            font-family: "Symbols Nerd Font Mono";
                                            font-size: 14px;
                                            color: FadeTheme.text-dim;
                                            vertical-alignment: center;
                                            width: 24px;
                                            horizontal-alignment: center;
                                        }
                                    }
                                }

                                // Inline "Add app to this group" input
                                if group.expanded: Rectangle {
                                    height: 36px;
                                    HorizontalBox {
                                        padding-left: 16px;
                                        padding-right: 8px;
                                        spacing: 6px;
                                        add-input := LineEdit {
                                            horizontal-stretch: 1;
                                            height: 28px;
                                            font-size: 12px;
                                            placeholder-text: "Add process name (e.g. notepad.exe) to this group";
                                            changed has-focus => {
                                                if (self.has-focus) {
                                                    root.confirming-delete-group = -1;
                                                }
                                            }
                                            accepted(val) => {
                                                root.add-to-group(g-idx, val);
                                                add-input.text = "";
                                            }
                                        }
                                        Rectangle {
                                            width: 28px;
                                            height: 28px;
                                            border-radius: 4px;
                                            background: add-grp-btn-ta.has-hover ? FadeTheme.accent : FadeTheme.surface;
                                            border-width: 1px;
                                            border-color: FadeTheme.border;
                                            add-grp-btn-ta := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.confirming-delete-group = -1;
                                                    root.add-to-group(g-idx, add-input.text);
                                                    add-input.text = "";
                                                }
                                            }
                                            Text {
                                                text: "+";
                                                font-size: 16px;
                                                font-weight: 700;
                                                color: add-grp-btn-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                // App rows within this group
                                if group.expanded: VerticalBox {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    padding-bottom: 8px;
                                    spacing: 2px;

                                    for app[a-idx] in group.apps: Rectangle {
                                        height: 44px;
                                        border-radius: 4px;
                                        background: app-row-ta.has-hover ? FadeTheme.surface-hover : FadeTheme.surface;
                                        app-row-ta := TouchArea {
                                            clicked => { root.confirming-delete-group = -1; }
                                        }

                                        HorizontalBox {
                                            height: 44px;
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 8px;

                                            VerticalLayout {
                                                alignment: center;
                                                FadeCheck {
                                                    checked: app.enabled;
                                                    toggled => { root.toggle-app(g-idx, a-idx, self.checked); }
                                                }
                                            }
                                            Rectangle {
                                                width: 28px;
                                                height: 28px;
                                                border-radius: 4px;
                                                background: app-icon-ta.has-hover ? FadeTheme.surface-hover : transparent;
                                                app-icon-ta := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.confirming-delete-group = -1;
                                                        root.icon-picker-group = g-idx;
                                                        root.icon-picker-app = a-idx;
                                                        root.icon-search-text = "";
                                                    root.icon-hovered-name = "";
                                                        root.icon-search-changed("");
                                                    }
                                                }
                                                BrandIcon {
                                                    icon: app.icon;
                                                    size: 18px;
                                                    tint: FadeTheme.accent;
                                                }
                                            }
                                            Text {
                                                text: app.process;
                                                color: FadeTheme.text;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                                min-width: 210px;
                                                horizontal-stretch: 1;
                                                overflow: elide;
                                            }

                                            // Inline custom controls — only when customized.
                                            // Label stacked above slider to save horizontal space.
                                            if app.customized: Rectangle {
                                                width: 110px;
                                                VerticalLayout {
                                                    spacing: 2px;
                                                    Text {
                                                        text: Math.round(app-slider.value) * 5 + " min";
                                                        color: FadeTheme.text;
                                                        font-size: 11px;
                                                        horizontal-alignment: center;
                                                    }
                                                    app-slider := Slider {
                                                        minimum: 1;
                                                        maximum: 24;
                                                        value: Math.ceil(app.timeout-mins / 5);
                                                        changed(val) => {
                                                            root.confirming-delete-group = -1;
                                                            root.update-app-timeout(g-idx, a-idx, Math.round(val) * 5);
                                                        }
                                                    }
                                                }
                                            }
                                            if app.customized: ComboBox {
                                                width: 95px;
                                                height: 26px;
                                                model: ["minimize", "close"];
                                                current-value: app.action;
                                                selected(val) => {
                                                    root.confirming-delete-group = -1;
                                                    root.update-app-action(g-idx, a-idx, val);
                                                }
                                            }

                                            // Customize / Reset button
                                            if !app.customized: Rectangle {
                                                width: 64px;
                                                height: 26px;
                                                border-radius: 4px;
                                                background: cust-ta.has-hover ? FadeTheme.surface-hover : FadeTheme.surface;
                                                border-width: 1px;
                                                border-color: FadeTheme.border;
                                                cust-ta := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.confirming-delete-group = -1;
                                                        root.customize-app(g-idx, a-idx);
                                                    }
                                                }
                                                Text {
                                                    text: "Edit";
                                                    font-size: 12px;
                                                    color: cust-ta.has-hover ? FadeTheme.accent : FadeTheme.text-dim;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            if app.customized: Rectangle {
                                                width: 64px;
                                                height: 26px;
                                                border-radius: 4px;
                                                background: reset-ta.has-hover ? FadeTheme.warning : FadeTheme.surface;
                                                border-width: 1px;
                                                border-color: FadeTheme.border;
                                                reset-ta := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.confirming-delete-group = -1;
                                                        root.reset-app-to-group(g-idx, a-idx);
                                                    }
                                                }
                                                Text {
                                                    text: "Reset";
                                                    font-size: 12px;
                                                    color: reset-ta.has-hover ? FadeTheme.bg : FadeTheme.text-dim;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            // Kebab (move) button
                                            Rectangle {
                                                width: 26px;
                                                height: 26px;
                                                border-radius: 4px;
                                                background: kebab-ta.has-hover ? FadeTheme.surface-hover : transparent;
                                                kebab-ta := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.confirming-delete-group = -1;
                                                        root.kebab-group = g-idx;
                                                        root.kebab-app = a-idx;
                                                    }
                                                }
                                                Text {
                                                    text: "\u{F01D9}";
                                                    font-family: "Symbols Nerd Font Mono";
                                                    font-size: 14px;
                                                    color: kebab-ta.has-hover ? FadeTheme.accent : FadeTheme.text-dim;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            // Always-visible delete
                                            FadeDeleteButton {
                                                clicked => {
                                                    root.confirming-delete-group = -1;
                                                    root.delete-app-from-group(g-idx, a-idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }


                        // ── Unassigned Rules section ──
                        if root.unassigned-rules.length > 0: Rectangle {
                            border-radius: FadeTheme.radius;
                            background: FadeTheme.card-bg;
                            border-width: 1px;
                            border-color: FadeTheme.border;

                            VerticalBox {
                                padding: 0px;
                                spacing: 0px;

                                // Header
                                Rectangle {
                                    height: 40px;
                                    border-radius: FadeTheme.radius;
                                    background: FadeTheme.card-header-bg;
                                    HorizontalBox {
                                        padding-left: 12px;
                                        spacing: 8px;
                                        Text {
                                            text: "Ungrouped";
                                            color: FadeTheme.text;
                                            font-size: 13px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Unassigned rule rows
                                VerticalBox {
                                    padding: 8px;
                                    spacing: 2px;

                                    for urule[u-idx] in root.unassigned-rules: Rectangle {
                                        height: 44px;
                                        border-radius: 4px;
                                        background: u-ta.has-hover ? FadeTheme.surface-hover : FadeTheme.surface;
                                        u-ta := TouchArea {
                                            clicked => { root.confirming-delete-group = -1; }
                                        }

                                        HorizontalBox {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 8px;

                                            VerticalLayout {
                                                alignment: center;
                                                FadeCheck {
                                                    checked: urule.enabled;
                                                    toggled => { root.toggle-unassigned(u-idx, self.checked); }
                                                }
                                            }
                                            Rectangle {
                                                width: 28px;
                                                height: 28px;
                                                border-radius: 4px;
                                                background: transparent;
                                                BrandIcon {
                                                    icon: urule.icon;
                                                    size: 18px;
                                                    tint: FadeTheme.accent;
                                                }
                                            }
                                            Text {
                                                text: urule.process;
                                                color: FadeTheme.text;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                                min-width: 210px;
                                                horizontal-stretch: 1;
                                                overflow: elide;
                                            }
                                            Rectangle {
                                                width: 110px;
                                                VerticalLayout {
                                                    spacing: 2px;
                                                    Text {
                                                        text: Math.round(u-slider.value) * 5 + " min";
                                                        color: FadeTheme.text;
                                                        font-size: 11px;
                                                        horizontal-alignment: center;
                                                    }
                                                    u-slider := Slider {
                                                        minimum: 1;
                                                        maximum: 24;
                                                        value: Math.ceil(urule.timeout-mins / 5);
                                                        changed(val) => {
                                                            root.confirming-delete-group = -1;
                                                            root.update-unassigned-timeout(u-idx, Math.round(val) * 5);
                                                        }
                                                    }
                                                }
                                            }
                                            ComboBox {
                                                width: 95px;
                                                height: 26px;
                                                model: ["minimize", "close"];
                                                current-value: urule.action;
                                                selected(val) => {
                                                    root.confirming-delete-group = -1;
                                                    root.update-unassigned-action(u-idx, val);
                                                }
                                            }
                                            // Assign-to-group kebab
                                            Rectangle {
                                                width: 26px;
                                                height: 26px;
                                                border-radius: 4px;
                                                background: u-kebab-ta.has-hover ? FadeTheme.surface-hover : transparent;
                                                u-kebab-ta := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.confirming-delete-group = -1;
                                                        root.unassigned-kebab = u-idx;
                                                    }
                                                }
                                                Text {
                                                    text: "\u{F01D9}";
                                                    font-family: "Symbols Nerd Font Mono";
                                                    font-size: 13px;
                                                    color: u-kebab-ta.has-hover ? FadeTheme.accent : FadeTheme.text-dim;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            // Remove button
                                            FadeDeleteButton {
                                                clicked => {
                                                    root.confirming-delete-group = -1;
                                                    root.remove-unassigned(u-idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ── "+ New Group" button (always at bottom of list) ──
                        Rectangle {
                            height: 44px;
                            border-radius: FadeTheme.radius;
                            background: new-grp-ta.has-hover ? FadeTheme.surface-hover : FadeTheme.card-bg;
                            border-width: 1px;
                            border-color: FadeTheme.border;
                            new-grp-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.create-group();
                                }
                            }
                            HorizontalBox {
                                alignment: center;
                                spacing: 6px;
                                Text {
                                    text: "\u{F0415}";
                                    font-family: "Symbols Nerd Font Mono";
                                    font-size: 15px;
                                    color: new-grp-ta.has-hover ? FadeTheme.accent : FadeTheme.text-dim;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: "New Group";
                                    color: new-grp-ta.has-hover ? FadeTheme.accent : FadeTheme.text-dim;
                                    font-size: 13px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Bottom bar ──
                HorizontalBox {
                    spacing: 8px;
                    alignment: space-between;
                    HorizontalBox {
                        spacing: 4px;
                        Text {
                            text: "\u{F04CC}";
                            font-family: "Symbols Nerd Font Mono";
                            font-size: 12px;
                            color: FadeTheme.text-dim;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.managed-count + " managed apps";
                            color: FadeTheme.text-dim;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 180px;
                        height: 32px;
                        border-radius: FadeTheme.radius;
                        background: add-new-ta.has-hover ? FadeTheme.accent : FadeTheme.surface;
                        add-new-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.confirming-delete-group = -1;
                                root.drawer-open = !root.drawer-open;
                            }
                        }
                        HorizontalBox {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 6px;
                            alignment: center;
                            Text {
                                text: "+";
                                color: add-new-ta.has-hover ? FadeTheme.bg : FadeTheme.accent;
                                font-size: 14px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Add New Managed App";
                                color: add-new-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                font-size: 13px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // Page 1: General Settings
            if root.current-page == 1: VerticalBox {
                padding: 20px;
                spacing: 16px;

                Text {
                    text: "Settings";
                    color: FadeTheme.text;
                    font-size: 18px;
                    font-weight: 700;
                }

                HorizontalBox {
                    spacing: FadeTheme.spacing;
                    Text { text: "Polling interval:"; color: FadeTheme.text; vertical-alignment: center; width: 150px; }
                    ComboBox {
                        width: 120px;
                        model: ["15 sec", "30 sec", "60 sec", "120 sec"];
                        current-value: root.polling-interval-secs == 15 ? "15 sec" :
                                       root.polling-interval-secs == 60 ? "60 sec" :
                                       root.polling-interval-secs == 120 ? "120 sec" :
                                       root.polling-interval-secs + " sec";
                        selected(val) => {
                            if (val == "15 sec") { root.set-polling-interval(15); }
                            if (val == "30 sec") { root.set-polling-interval(30); }
                            if (val == "60 sec") { root.set-polling-interval(60); }
                            if (val == "120 sec") { root.set-polling-interval(120); }
                        }
                    }
                }

                HorizontalBox {
                    spacing: FadeTheme.spacing;
                    Text { text: "Start with Windows:"; color: FadeTheme.text; vertical-alignment: center; width: 150px; }
                    FadeCheck {
                        checked: root.auto-start;
                        toggled => { root.set-auto-start(self.checked); }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // ── Danger Zone: Restore Defaults ──
                Rectangle {
                    height: 110px;
                    border-radius: FadeTheme.radius;
                    background: FadeTheme.card-bg;
                    border-width: 1px;
                    border-color: FadeTheme.danger;

                    VerticalBox {
                        padding: 14px;
                        spacing: 8px;

                        Text {
                            text: "Danger Zone";
                            color: FadeTheme.danger;
                            font-size: 13px;
                            font-weight: 700;
                        }

                        HorizontalBox {
                            padding: 0px;
                            spacing: 12px;

                            VerticalBox {
                                padding: 0px;
                                spacing: 2px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Restore defaults";
                                    color: FadeTheme.text;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "Wipes custom rules, added processes, and all group customizations. Cannot be undone.";
                                    color: FadeTheme.text-dim;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }

                            if !root.confirming-reset: Rectangle {
                                width: 140px;
                                height: 30px;
                                border-radius: 4px;
                                background: reset-btn-ta.has-hover ? FadeTheme.danger : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.danger;
                                reset-btn-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.confirming-reset = true; }
                                }
                                Text {
                                    text: "Restore Defaults";
                                    color: reset-btn-ta.has-hover ? FadeTheme.bg : FadeTheme.danger;
                                    font-size: 12px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            if root.confirming-reset: Rectangle {
                                width: 80px;
                                height: 30px;
                                border-radius: 4px;
                                background: yes-ta.has-hover ? FadeTheme.danger : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.danger;
                                yes-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.restore-defaults();
                                        root.confirming-reset = false;
                                    }
                                }
                                Text {
                                    text: "Yes, reset";
                                    color: yes-ta.has-hover ? FadeTheme.bg : FadeTheme.danger;
                                    font-size: 12px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            if root.confirming-reset: Rectangle {
                                width: 70px;
                                height: 30px;
                                border-radius: 4px;
                                background: no-ta.has-hover ? FadeTheme.surface-hover : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.border;
                                no-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.confirming-reset = false; }
                                }
                                Text {
                                    text: "Cancel";
                                    color: FadeTheme.text;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Status bar
                Rectangle {
                    height: 28px;
                    background: FadeTheme.status-bar-bg;
                    border-radius: FadeTheme.radius;
                    Text {
                        text: "Fade v" + root.version;
                        color: FadeTheme.status-bar-text;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Page 2: Activity
            if root.current-page == 2: VerticalBox {
                padding: 20px;
                spacing: 12px;

                Text {
                    text: "Activity";
                    color: FadeTheme.text;
                    font-size: 18px;
                    font-weight: 700;
                }
                Text {
                    text: "Most recent " + root.activity-log.length + " actions Fade has taken. Logs reset on restart.";
                    color: FadeTheme.text-dim;
                    font-size: 12px;
                }

                // Currently-open apps section
                Text {
                    text: "Currently open (" + root.current-apps.length + ")";
                    color: FadeTheme.text;
                    font-size: 14px;
                    font-weight: 600;
                }
                if root.current-apps.length == 0: Rectangle {
                    height: 40px;
                    border-radius: FadeTheme.radius;
                    background: FadeTheme.card-bg;
                    border-width: 1px;
                    border-color: FadeTheme.border;
                    Text {
                        text: "No tracked windows right now.";
                        color: FadeTheme.text-dim;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                if root.current-apps.length > 0: Rectangle {
                    max-height: 220px;
                    border-radius: FadeTheme.radius;
                    background: FadeTheme.card-bg;
                    border-width: 1px;
                    border-color: FadeTheme.border;
                    ScrollView {
                        VerticalBox {
                            padding: 4px;
                            spacing: 2px;
                            for app in root.current-apps: Rectangle {
                                height: 30px;
                                border-radius: 4px;
                                background: FadeTheme.surface;
                                BrandIcon {
                                    x: 10px;
                                    y: (parent.height - self.height) / 2;
                                    icon: app.icon;
                                    size: 16px;
                                    tint: app.managed ? FadeTheme.accent : FadeTheme.text-dim;
                                }
                                Text {
                                    x: 42px;
                                    y: (parent.height - self.height) / 2;
                                    width: parent.width - 42px - 180px;
                                    text: app.process_name;
                                    color: FadeTheme.text;
                                    font-size: 13px;
                                    overflow: elide;
                                }
                                Text {
                                    x: parent.width - 170px;
                                    y: (parent.height - self.height) / 2;
                                    width: 60px;
                                    text: app.managed ? "tracked" : "";
                                    color: FadeTheme.accent;
                                    font-size: 10px;
                                    horizontal-alignment: right;
                                }
                                Text {
                                    x: parent.width - 100px;
                                    y: (parent.height - self.height) / 2;
                                    width: 90px;
                                    text: app.idle_str;
                                    color: FadeTheme.text-dim;
                                    font-size: 12px;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "Action log";
                    color: FadeTheme.text;
                    font-size: 14px;
                    font-weight: 600;
                }

                if root.activity-log.length == 0: Rectangle {
                    height: 80px;
                    border-radius: FadeTheme.radius;
                    background: FadeTheme.card-bg;
                    border-width: 1px;
                    border-color: FadeTheme.border;
                    Text {
                        text: "No activity yet — Fade hasn't minimized or closed any windows in this session.";
                        color: FadeTheme.text-dim;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        wrap: word-wrap;
                    }
                }

                if root.activity-log.length > 0: ScrollView {
                    vertical-stretch: 1;
                    VerticalBox {
                        padding: 0px;
                        spacing: 2px;
                        for entry in root.activity-log: Rectangle {
                            height: 36px;
                            border-radius: 4px;
                            background: FadeTheme.surface;
                            HorizontalBox {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;
                                BrandIcon {
                                    icon: entry.icon;
                                    size: 16px;
                                    tint: FadeTheme.accent;
                                }
                                Text {
                                    text: entry.process;
                                    color: FadeTheme.text;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    width: 150px;
                                    overflow: elide;
                                }
                                Text {
                                    text: entry.action;
                                    color: entry.action == "close" ? FadeTheme.danger : FadeTheme.text-dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    width: 70px;
                                }
                                Text {
                                    text: entry.title;
                                    color: FadeTheme.text-dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Text {
                                    text: entry.time_str;
                                    color: FadeTheme.text-dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-alignment: right;
                                    width: 70px;
                                }
                            }
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; }
            }

            // ── Kebab menu (floating overlay: Move to / Remove) ──
            if root.kebab-group != -1: Rectangle {
                // Full-area scrim to catch click-outside
                background: transparent;
                TouchArea {
                    clicked => {
                        root.confirming-delete-group = -1;
                        root.kebab-group = -1;
                        root.kebab-app = -1;
                    }
                }
                // Menu panel, centered
                Rectangle {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 260px;
                    height: Math.min(480px, 60px + root.groups.length * 32px + 80px);
                    background: FadeTheme.drawer-bg;
                    border-radius: FadeTheme.radius;
                    border-width: 1px;
                    border-color: FadeTheme.drawer-border;
                    drop-shadow-blur: 16px;
                    drop-shadow-color: #00000066;
                    // Block scrim clicks inside the panel
                    TouchArea {}

                    VerticalBox {
                        padding: 10px;
                        spacing: 4px;

                        // Reorder row
                        HorizontalBox {
                            padding: 0px;
                            spacing: 6px;
                            height: 32px;
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 28px;
                                border-radius: 4px;
                                background: up-ta.has-hover ? FadeTheme.accent : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.border;
                                up-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.confirming-delete-group = -1;
                                        root.move-app-up(root.kebab-group, root.kebab-app);
                                        root.kebab-group = -1;
                                        root.kebab-app = -1;
                                    }
                                }
                                Text {
                                    text: "▲ Move up";
                                    color: up-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 28px;
                                border-radius: 4px;
                                background: down-ta.has-hover ? FadeTheme.accent : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.border;
                                down-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.confirming-delete-group = -1;
                                        root.move-app-down(root.kebab-group, root.kebab-app);
                                        root.kebab-group = -1;
                                        root.kebab-app = -1;
                                    }
                                }
                                Text {
                                    text: "▼ Move down";
                                    color: down-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        HorizontalBox {
                            padding: 0px;
                            spacing: 4px;
                            Text {
                                text: "Move to group:";
                                color: FadeTheme.text-dim;
                                font-size: 11px;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 4px;
                                background: kebab-close-ta.has-hover ? FadeTheme.danger : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.border;
                                kebab-close-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.confirming-delete-group = -1;
                                        root.kebab-group = -1;
                                        root.kebab-app = -1;
                                    }
                                }
                                Text {
                                    text: "✕";
                                    color: kebab-close-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        for dest[d-idx] in root.groups: Rectangle {
                            height: d-idx == root.kebab-group ? 0px : 30px;
                            border-radius: 4px;
                            background: dest-ta.has-hover ? FadeTheme.surface-hover : transparent;
                            visible: d-idx != root.kebab-group;
                            dest-ta := TouchArea {
                                mouse-cursor: pointer;
                                enabled: d-idx != root.kebab-group;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.move-app(root.kebab-group, root.kebab-app, d-idx);
                                    root.kebab-group = -1;
                                    root.kebab-app = -1;
                                }
                            }
                            HorizontalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                BrandIcon {
                                    icon: dest.icon;
                                    size: 16px;
                                    tint: FadeTheme.accent;
                                }
                                Text {
                                    text: dest.name;
                                    color: FadeTheme.text;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: FadeTheme.border; }

                        Rectangle {
                            height: 30px;
                            border-radius: 4px;
                            background: new-k-ta.has-hover ? FadeTheme.surface-hover : transparent;
                            new-k-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.move-to-new-group(root.kebab-group, root.kebab-app);
                                    root.kebab-group = -1;
                                    root.kebab-app = -1;
                                }
                            }
                            HorizontalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                Text {
                                    text: "\u{F0415}";
                                    font-family: "Symbols Nerd Font Mono";
                                    font-size: 14px;
                                    color: new-k-ta.has-hover ? FadeTheme.accent : FadeTheme.text;
                                    vertical-alignment: center;
                                    width: 20px;
                                }
                                Text {
                                    text: "Move to new group";
                                    color: new-k-ta.has-hover ? FadeTheme.accent : FadeTheme.text;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle {
                            height: 30px;
                            border-radius: 4px;
                            background: remove-ta.has-hover ? FadeTheme.danger : transparent;
                            remove-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.remove-from-group(root.kebab-group, root.kebab-app);
                                    root.kebab-group = -1;
                                    root.kebab-app = -1;
                                }
                            }
                            Text {
                                text: "Move to Ungrouped";
                                color: remove-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                font-size: 13px;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                                x: 10px;
                            }
                        }

                    }
                }
            }

            // ── Unassigned kebab menu (Assign to group) ──
            if root.unassigned-kebab != -1: Rectangle {
                background: transparent;
                TouchArea {
                    clicked => {
                        root.confirming-delete-group = -1;
                        root.unassigned-kebab = -1;
                    }
                }
                Rectangle {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 260px;
                    height: Math.min(460px, 50px + root.groups.length * 32px + 40px);
                    background: FadeTheme.drawer-bg;
                    border-radius: FadeTheme.radius;
                    border-width: 1px;
                    border-color: FadeTheme.drawer-border;
                    drop-shadow-blur: 16px;
                    drop-shadow-color: #00000066;
                    TouchArea {}

                    VerticalBox {
                        padding: 10px;
                        spacing: 4px;
                        HorizontalBox {
                            padding: 0px;
                            spacing: 4px;
                            Text {
                                text: "Assign to group:";
                                color: FadeTheme.text-dim;
                                font-size: 11px;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 4px;
                                background: uk-close-ta.has-hover ? FadeTheme.danger : FadeTheme.surface;
                                border-width: 1px;
                                border-color: FadeTheme.border;
                                uk-close-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.confirming-delete-group = -1;
                                        root.unassigned-kebab = -1;
                                    }
                                }
                                Text {
                                    text: "✕";
                                    color: uk-close-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        for dest[d-idx] in root.groups: Rectangle {
                            height: 30px;
                            border-radius: 4px;
                            background: ug-ta.has-hover ? FadeTheme.surface-hover : transparent;
                            ug-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.assign-to-group(root.unassigned-kebab, d-idx);
                                    root.unassigned-kebab = -1;
                                }
                            }
                            HorizontalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                BrandIcon {
                                    icon: dest.icon;
                                    size: 16px;
                                    tint: FadeTheme.accent;
                                }
                                Text {
                                    text: dest.name;
                                    color: FadeTheme.text;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: FadeTheme.border; }

                        Rectangle {
                            height: 30px;
                            border-radius: 4px;
                            background: unew-ta.has-hover ? FadeTheme.surface-hover : transparent;
                            unew-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.assign-to-new-group(root.unassigned-kebab);
                                    root.unassigned-kebab = -1;
                                }
                            }
                            HorizontalBox {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                Text {
                                    text: "\u{F0415}";
                                    font-family: "Symbols Nerd Font Mono";
                                    font-size: 14px;
                                    color: unew-ta.has-hover ? FadeTheme.accent : FadeTheme.text;
                                    vertical-alignment: center;
                                    width: 20px;
                                }
                                Text {
                                    text: "Assign to new group";
                                    color: unew-ta.has-hover ? FadeTheme.accent : FadeTheme.text;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }
            }

            // ── Icon Picker (floating overlay) ──
            if root.icon-picker-group != -1: Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 480px;
                height: 440px;
                background: FadeTheme.drawer-bg;
                border-radius: FadeTheme.radius;
                border-width: 1px;
                border-color: FadeTheme.drawer-border;
                drop-shadow-blur: 16px;
                drop-shadow-color: #00000066;

                VerticalBox {
                    padding: 12px;
                    spacing: 8px;

                    // Header
                    HorizontalBox {
                        spacing: 4px;
                        Text {
                            text: "Pick an icon";
                            color: FadeTheme.text;
                            font-size: 14px;
                            font-weight: 600;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 4px;
                            background: close-picker-ta.has-hover ? FadeTheme.danger : FadeTheme.surface;
                            border-width: 1px;
                            border-color: FadeTheme.border;
                            close-picker-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.icon-picker-group = -1;
                                    root.icon-picker-app = -1;
                                }
                            }
                            Text {
                                text: "✕";
                                font-size: 13px;
                                color: close-picker-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Search
                    icon-search-input := LineEdit {
                        height: 32px;
                        font-size: 13px;
                        placeholder-text: "Search icons...";
                        text <=> root.icon-search-text;
                        changed has-focus => {
                            if (self.has-focus) {
                                root.confirming-delete-group = -1;
                            }
                        }
                        edited(val) => {
                            root.icon-search-changed(val);
                        }
                    }

                    // Results grid
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalBox {
                            padding: 0px;
                            spacing: 6px;
                            for row[row-idx] in Math.ceil(root.icon-results.length / 10): HorizontalBox {
                                padding: 0px;
                                spacing: 6px;
                                for col in 10: Rectangle {
                                    width: 40px;
                                    height: 40px;
                                    border-radius: 4px;
                                    property <int> entry-idx: row-idx * 10 + col;
                                    property <bool> has-entry: self.entry-idx < root.icon-results.length;
                                    background: cell-ta.has-hover && self.has-entry ? FadeTheme.accent : FadeTheme.surface;
                                    border-width: self.has-entry ? 1px : 0px;
                                    border-color: FadeTheme.border;
                                    visible: self.has-entry;
                                    cell-ta := TouchArea {
                                        mouse-cursor: pointer;
                                        enabled: parent.has-entry;
                                        changed has-hover => {
                                            if (self.has-hover && parent.has-entry) {
                                                root.icon-hovered-name = root.icon-results[parent.entry-idx].keywords;
                                            }
                                        }
                                        clicked => {
                                            root.confirming-delete-group = -1;
                                            if (root.icon-picker-app == -1) {
                                                root.set-group-icon(root.icon-picker-group, root.icon-results[parent.entry-idx].glyph);
                                            } else {
                                                root.set-app-icon(root.icon-picker-group, root.icon-picker-app, root.icon-results[parent.entry-idx].glyph);
                                            }
                                            root.icon-picker-group = -1;
                                            root.icon-picker-app = -1;
                                        }
                                    }
                                    Text {
                                        text: parent.has-entry ? root.icon-results[parent.entry-idx].glyph : "";
                                        font-family: "Symbols Nerd Font Mono";
                                        font-size: 20px;
                                        color: cell-ta.has-hover ? FadeTheme.bg : FadeTheme.accent;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Footer: count + hovered keywords when searching
                    Text {
                        text: root.icon-search-text != "" && root.icon-hovered-name != ""
                            ? root.icon-hovered-name + "  —  " + root.icon-results.length + " matches"
                            : root.icon-results.length + " icon" + (root.icon-results.length == 1 ? "" : "s");
                        color: FadeTheme.text-dim;
                        font-size: 11px;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // ── Active Processes Drawer (floating overlay) ──
            if root.drawer-open: Rectangle {
                x: parent.width - 380px;
                y: parent.height - 400px;
                width: 370px;
                height: 390px;
                background: FadeTheme.drawer-bg;
                border-radius: FadeTheme.radius;
                border-width: 1px;
                border-color: FadeTheme.drawer-border;
                drop-shadow-blur: 16px;
                drop-shadow-color: #00000066;

                VerticalBox {
                    padding: 10px;
                    spacing: 6px;

                    // Drawer header
                    HorizontalBox {
                        spacing: 4px;
                        Text {
                            text: "Active Processes";
                            color: FadeTheme.text;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 4px;
                            background: close-drawer-ta.has-hover ? FadeTheme.danger : FadeTheme.surface;
                            border-width: 1px;
                            border-color: FadeTheme.border;
                            close-drawer-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.drawer-open = false;
                                }
                            }
                            Text {
                                text: "✕";
                                font-size: 13px;
                                color: close-drawer-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Active process list
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalBox {
                            spacing: 2px;
                            for proc[idx] in root.active-processes: Rectangle {
                                height: 32px;
                                border-radius: 4px;
                                background: proc-ta.has-hover ? FadeTheme.surface-hover : transparent;
                                proc-ta := TouchArea {}

                                HorizontalBox {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    spacing: 8px;
                                    BrandIcon {
                                        icon: proc.icon;
                                        size: 16px;
                                        tint: FadeTheme.accent;
                                    }
                                    Text {
                                        text: proc.process;
                                        color: FadeTheme.text;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        min-width: 120px;
                                        overflow: elide;
                                    }
                                    if !proc.managed: Rectangle {
                                        width: 44px;
                                        height: 22px;
                                        border-radius: 4px;
                                        background: add-proc-ta.has-hover ? FadeTheme.accent : FadeTheme.surface;
                                        border-width: 1px;
                                        border-color: FadeTheme.border;
                                        add-proc-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.confirming-delete-group = -1;
                                                root.add-rule(proc.process);
                                            }
                                        }
                                        Text {
                                            text: "Add";
                                            font-size: 11px;
                                            color: add-proc-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    if proc.managed: Text {
                                        text: "✓";
                                        font-size: 12px;
                                        color: FadeTheme.text-dim;
                                        width: 44px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Manual add row
                    HorizontalBox {
                        spacing: 6px;
                        height: 36px;
                        manual-input := LineEdit {
                            horizontal-stretch: 1;
                            height: 36px;
                            font-size: 13px;
                            placeholder-text: "Add process name";
                            changed has-focus => {
                                if (self.has-focus) {
                                    root.confirming-delete-group = -1;
                                }
                            }
                            accepted(val) => {
                                root.add-process-name(val);
                                manual-input.text = "";
                            }
                        }
                        Rectangle {
                            width: 36px;
                            height: 36px;
                            border-radius: 4px;
                            background: manual-add-ta.has-hover ? FadeTheme.accent : FadeTheme.surface;
                            manual-add-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.confirming-delete-group = -1;
                                    root.add-process-name(manual-input.text);
                                    manual-input.text = "";
                                }
                            }
                            Text {
                                text: "+";
                                font-size: 18px;
                                font-weight: 700;
                                color: manual-add-ta.has-hover ? FadeTheme.bg : FadeTheme.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Feedback toast
                    if root.drawer-status-kind != 0: Text {
                        text: root.drawer-status-text;
                        color: root.drawer-status-kind == 1 ? FadeTheme.accent
                             : root.drawer-status-kind == 2 ? FadeTheme.warning
                             : FadeTheme.danger;
                        font-size: 11px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
